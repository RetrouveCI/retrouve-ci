{
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "esnext"],
		"allowJs": true,
		"target": "ES6",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"incremental": true,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./*"],
			"@retrouve-ci/ui": ["../../packages/ui/src/index.ts"],
			"@retrouve-ci/ui/components": ["../../packages/ui/src/components/index.ts"],
			"@retrouve-ci/ui/utils": ["../../packages/ui/src/utils/cn.ts"],
			"@retrouve-ci/ui/hooks": ["../../packages/ui/src/hooks/index.ts"]
		}
	},
	"include": [
		"next-env.d.ts",
		"**/*.ts",
		"**/*.tsx",
		".next/types/**/*.ts",
		".next/dev/types/**/*.ts"
	],
	"exclude": ["node_modules"]
}
