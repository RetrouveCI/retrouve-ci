{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": [
		"NODE_ENV",
		"PORT",
		"DATABASE_URL",
		"PGBOUNCER_URL",
		"REDIS_URL",
		"BETTER_AUTH_SECRET",
		"BETTER_AUTH_URL",
		"BETTER_AUTH_TRUSTED_ORIGINS",
		"ALLOWED_ORIGINS",
		"ENABLE_SWAGGER",
		"VITE_API_URL",
		"SUPER_ADMIN_EMAIL",
		"SUPER_ADMIN_NAME",
		"SUPER_ADMIN_PASSWORD",
		"SEED_MOCK_USER_EMAIL",
		"SEED_MOCK_USER_NAME",
		"SEED_MOCK_USER_PASSWORD",
		"SEED_MOCK_USER_PHONE",
		"CLOUDINARY_CLOUD_NAME",
		"CLOUDINARY_API_KEY",
		"CLOUDINARY_API_SECRET",
		"CLOUDINARY_FOLDER"
	],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": [
				"dist/**",
				".next/**",
				"!.next/cache/**",
				"build/**",
				"src/generated/**"
			]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"db:generate": {
			"cache": true,
			"inputs": ["prisma/schema.prisma"],
			"outputs": ["src/generated/**"]
		},
		"db:migrate": {
			"cache": false
		},
		"db:deploy": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
