{
	"compilerOptions": {
		"lib": ["es2022", "DOM", "DOM.Iterable"],
		"allowJs": true,
		"target": "ES2022",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"strictNullChecks": true,
		"paths": {
			"@retrouveci/ui/*": ["./src/*"]
		}
	},
	"include": ["src"],
	"exclude": ["dist", "build", "node_modules"]
}
