{
	"name": "api",
	"version": "1.0.0",
	"private": true,
	"type": "commonjs",
	"files": [
		"dist"
	],
	"scripts": {
		"build": "nest build && tsc-alias -p tsconfig.build.json",
		"dev": "concurrently \"tsc-alias -p tsconfig.build.json -w\" \"nest start --watch\"",
		"start": "node dist/main.js",
		"lint": "eslint",
		"check-types": "tsc --noEmit",
		"test": "vitest run"
	},
	"dependencies": {
		"@fastify/multipart": "^10.0.0",
		"@fastify/static": "^8.3.0",
		"@nestjs/bullmq": "11.0.4",
		"@nestjs/common": "11.1.26",
		"@nestjs/config": "4.0.4",
		"@nestjs/core": "11.1.26",
		"@nestjs/platform-fastify": "11.1.26",
		"@nestjs/swagger": "^11.4.4",
		"@retrouve-ci/database": "workspace:*",
		"@thallesp/nestjs-better-auth": "2.6.1",
		"better-auth": "1.6.18",
		"bullmq": "5.78.0",
		"class-transformer": "^0.5.1",
		"class-validator": "^0.15.1",
		"cloudinary": "^2.10.0",
		"dotenv": "^17.4.2",
		"fastify": "5.8.5",
		"reflect-metadata": "0.2.2",
		"rxjs": "7.8.2"
	},
	"devDependencies": {
		"@nestjs/cli": "11.0.23",
		"@nestjs/schematics": "11.1.0",
		"@nestjs/testing": "11.1.26",
		"@retrouve-ci/eslint-config": "workspace:*",
		"@retrouve-ci/typescript-config": "workspace:*",
		"@retrouve-ci/vitest-config": "workspace:*",
		"@types/node": "catalog:",
		"concurrently": "^10.0.3",
		"eslint": "catalog:",
		"source-map-support": "0.5.21",
		"tsc-alias": "^1.8.17",
		"typescript": "catalog:",
		"vitest": "catalog:"
	}
}
