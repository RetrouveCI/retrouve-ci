{
	"$schema": "https://docs.renovatebot.com/renovate-schema.json",
	"extends": [
		"config:recommended",
		":dependencyDashboard",
		":separateMajorReleases",
		"group:monorepos",
		"group:recommended"
	],
	"reviewers": ["@JoelDigbeu", "JowellDev"],
	"labels": ["dependencies"],
	"schedule": ["before 6am on Monday"],
	"prConcurrentLimit": 5,
	"prHourlyLimit": 2,
	"packageRules": [
		{
			"description": "Regroupe Next.js, React et les types associés",
			"matchPackageNames": [
				"next",
				"react",
				"react-dom",
				"@types/react",
				"@types/react-dom"
			],
			"groupName": "React & Next.js",
			"groupSlug": "react-nextjs"
		},
		{
			"description": "Regroupe Tailwind CSS et ses plugins",
			"matchPackagePatterns": ["^tailwindcss", "^@tailwindcss/"],
			"groupName": "Tailwind CSS",
			"groupSlug": "tailwindcss"
		},
		{
			"description": "Regroupe les composants Radix UI (utilisés par shadcn/ui)",
			"matchPackagePatterns": ["^@radix-ui/"],
			"groupName": "Radix UI",
			"groupSlug": "radix-ui"
		},
		{
			"description": "Regroupe tous les @types/* sauf react",
			"matchPackagePatterns": ["^@types/"],
			"excludePackageNames": ["@types/react", "@types/react-dom"],
			"groupName": "TypeScript @types",
			"groupSlug": "types"
		},
		{
			"description": "Regroupe ESLint et ses plugins",
			"matchPackagePatterns": ["^eslint", "^@eslint/"],
			"groupName": "ESLint",
			"groupSlug": "eslint"
		},
		{
			"description": "Automerge les mises à jour de patch et minor des devDeps",
			"matchDepTypes": ["devDependencies"],
			"matchUpdateTypes": ["patch", "minor"],
			"automerge": true,
			"automergeType": "pr"
		},
		{
			"description": "Pas d'automerge sur les deps de production (sécurité)",
			"matchDepTypes": ["dependencies", "peerDependencies"],
			"automerge": false
		}
	],
	"ignorePaths": ["**/node_modules/**", "**/.next/**"]
}
