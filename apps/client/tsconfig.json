{
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "esnext"],
		"types": ["vite/client"],
		"allowJs": true,
		"target": "ES2022",
		"skipLibCheck": true,
		"strict": true,
		"noEmit": true,
		"esModuleInterop": true,
		"module": "esnext",
		"moduleResolution": "bundler",
		"resolveJsonModule": true,
		"isolatedModules": true,
		"jsx": "react-jsx",
		"rootDirs": [".", "./.react-router/types"],
		"paths": {
			"@/*": ["./app/*"],
			"@retrouve-ci/ui": ["../../packages/ui/src/index.ts"],
			"@retrouve-ci/ui/components": ["../../packages/ui/src/components/index.ts"],
			"@retrouve-ci/ui/components/form": ["../../packages/ui/src/components/form/index.ts"],
			"@retrouve-ci/ui/utils": ["../../packages/ui/src/utils/cn.ts"],
			"@retrouve-ci/ui/hooks": ["../../packages/ui/src/hooks/index.ts"]
		}
	},
	"include": [".react-router/types/**/*", "**/*.ts", "**/*.tsx", "vite.config.ts"],
	"exclude": ["node_modules", "build"]
}
