{
	"$schema": "https://turborepo.dev/schema.json",
	"ui": "tui",
	"globalEnv": ["NODE_ENV", "PORT", "DATABASE_URL", "PGBOUNCER_URL", "REDIS_URL", "BETTER_AUTH_SECRET", "BETTER_AUTH_URL"],
	"tasks": {
		"build": {
			"dependsOn": ["^build"],
			"inputs": ["$TURBO_DEFAULT$", ".env*"],
			"outputs": ["dist/**", ".next/**", "!.next/cache/**", "src/generated/**"]
		},
		"lint": {
			"dependsOn": ["^lint"]
		},
		"check-types": {
			"dependsOn": ["^check-types"]
		},
		"test": {
			"dependsOn": ["^build"]
		},
		"db:generate": {
			"cache": true,
			"inputs": ["prisma/schema.prisma"],
			"outputs": ["src/generated/**"]
		},
		"db:migrate": {
			"cache": false
		},
		"db:deploy": {
			"cache": false
		},
		"db:studio": {
			"cache": false,
			"persistent": true
		},
		"dev": {
			"cache": false,
			"persistent": true
		}
	}
}
