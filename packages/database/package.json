{
	"name": "@retrouve-ci/database",
	"version": "0.0.0",
	"private": true,
	"type": "commonjs",
	"files": [
		"dist",
		"prisma",
		"prisma.config.ts"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"default": "./dist/index.js"
		}
	},
	"scripts": {
		"build": "prisma generate && tsc -p tsconfig.build.json",
		"check-types": "tsc --noEmit",
		"db:generate": "prisma generate",
		"db:migrate": "prisma migrate dev",
		"db:deploy": "prisma migrate deploy",
		"db:studio": "prisma studio"
	},
	"dependencies": {
		"@prisma/adapter-pg": "7.8.0",
		"@prisma/client": "7.8.0",
		"pg": "8.16.3"
	},
	"devDependencies": {
		"@retrouve-ci/typescript-config": "workspace:*",
		"@types/node": "catalog:",
		"@types/pg": "8.15.5",
		"dotenv": "17.4.2",
		"prisma": "7.8.0",
		"typescript": "catalog:"
	}
}
