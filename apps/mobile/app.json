{
  "expo": {
    "name": "RetrouveCI",
    "slug": "retrouveci",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "retrouveci",
    "userInterfaceStyle": "automatic",
    "ios": {
      "icon": "./assets/expo.icon"
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#208AEF",
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 76
          }
        }
      ],
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "RetrouveCI utilise la caméra pour scanner les QR codes des stickers."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "RetrouveCI accède à vos photos pour illustrer vos annonces."
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "RetrouveCI utilise votre position pour localiser les objets à proximité."
        }
      ],
      "expo-notifications",
      [
        "expo-font",
        {
          "fonts": [
            "./assets/fonts/Geist/Geist-Light.ttf",
            "./assets/fonts/Geist/Geist-Regular.ttf",
            "./assets/fonts/Geist/Geist-Medium.ttf",
            "./assets/fonts/Geist/Geist-SemiBold.ttf",
            "./assets/fonts/Geist/Geist-Bold.ttf"
          ]
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
